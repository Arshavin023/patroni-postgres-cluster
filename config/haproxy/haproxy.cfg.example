# ─────────────────────────────────────────────────────────────────────────────
# HAProxy Configuration Template
#
# This config is co-located on every PostgreSQL node.
# The backend server lists are identical across all three nodes.
# The only node-specific lines are in the NLB health check frontends at the
# bottom — update the srv_is_up() server references to match THIS node's name.
#
# Replace every PLACEHOLDER_ value before deploying.
# ─────────────────────────────────────────────────────────────────────────────

global
    maxconn 500
    log /dev/log local0

defaults
    log global
    mode tcp
    retries 2
    timeout client  30m
    timeout connect 4s
    timeout server  30m
    timeout check   5s

# ─────────────────────────────────────────────────────────────────────────────
# WRITES → True Primary Only (Port 5000)
#
# HAProxy calls GET /primary on Patroni's REST API (port 8008).
# Only the current Patroni leader returns HTTP 200.
# All replicas return 503 — HAProxy never routes writes to them.
# ─────────────────────────────────────────────────────────────────────────────
frontend pg_writes
    bind *:5000
    mode tcp
    option tcplog
    default_backend primary_node

backend primary_node
    mode tcp
    option httpchk GET /primary
    http-check expect status 200
    # inter 3s  = health check every 3 seconds
    # fall 3    = mark DOWN after 3 consecutive failures (max 9s to detect)
    # rise 2    = mark UP after 2 consecutive successes
    # on-marked-down shutdown-sessions = drop existing connections immediately
    default-server inter 3s fall 3 rise 2 on-marked-down shutdown-sessions
    server pg-node-1 PLACEHOLDER_PG_NODE_1_IP:5432 maxconn 300 check port 8008
    server pg-node-2 PLACEHOLDER_PG_NODE_2_IP:5432 maxconn 300 check port 8008
    server pg-node-3 PLACEHOLDER_PG_NODE_3_IP:5432 maxconn 300 check port 8008

# ─────────────────────────────────────────────────────────────────────────────
# READS → Replicas preferred, Primary as fallback (Port 5001)
#
# HAProxy calls GET /replica on port 8008.
# Active replicas return 200. The leader returns 503 for /replica.
# If NO replicas are healthy, falls back to primary_reads_fallback.
# ─────────────────────────────────────────────────────────────────────────────
frontend pg_reads
    bind *:5001
    mode tcp
    option tcplog
    acl has_replica nbsrv(replica_nodes) gt 0
    use_backend replica_nodes if has_replica
    default_backend primary_reads_fallback

backend replica_nodes
    mode tcp
    balance roundrobin
    option httpchk GET /replica
    http-check expect status 200
    default-server inter 3s fall 3 rise 2 on-marked-down shutdown-sessions
    server pg-node-1 PLACEHOLDER_PG_NODE_1_IP:5432 maxconn 300 check port 8008
    server pg-node-2 PLACEHOLDER_PG_NODE_2_IP:5432 maxconn 300 check port 8008
    server pg-node-3 PLACEHOLDER_PG_NODE_3_IP:5432 maxconn 300 check port 8008

backend primary_reads_fallback
    mode tcp
    option httpchk GET /primary
    http-check expect status 200
    default-server inter 3s fall 3 rise 2 on-marked-down shutdown-sessions
    server pg-node-1 PLACEHOLDER_PG_NODE_1_IP:5432 maxconn 300 check port 8008
    server pg-node-2 PLACEHOLDER_PG_NODE_2_IP:5432 maxconn 300 check port 8008
    server pg-node-3 PLACEHOLDER_PG_NODE_3_IP:5432 maxconn 300 check port 8008

# ─────────────────────────────────────────────────────────────────────────────
# HAProxy Stats Dashboard (Port 7000) — internal access only
# Access: http://NODE_IP:7000/haproxy
# ─────────────────────────────────────────────────────────────────────────────
listen stats
    mode http
    bind *:7000
    stats enable
    stats uri /haproxy
    stats refresh 5s

# ─────────────────────────────────────────────────────────────────────────────
# NLB Health Check Endpoints
#
# The AWS NLB health-checks these HTTP ports to decide whether to route traffic
# to this EC2 instance. This is a coarser check than the backend routing above.
#
# Port 9000: returns 200 if the write backend (primary) is reachable via THIS node
# Port 9001: returns 200 if a readable backend (replica or primary fallback) is
#            reachable via THIS node
#
# NODE-SPECIFIC: Update the srv_is_up() server name to match THIS node.
# On pg-node-1: use pg-node-1
# On pg-node-2: use pg-node-2
# On pg-node-3: use pg-node-3
# ─────────────────────────────────────────────────────────────────────────────
frontend nlb_writes_healthcheck
    bind *:9000
    mode http
    monitor-uri /health
    # Change pg-node-1 to this node's name
    monitor fail unless { srv_is_up(primary_node/pg-node-1) }

frontend nlb_reads_healthcheck
    bind *:9001
    mode http
    monitor-uri /health
    # Change pg-node-1 to this node's name in all three acl lines
    acl is_replica  srv_is_up(replica_nodes/pg-node-1)
    acl is_primary  srv_is_up(primary_node/pg-node-1)
    acl no_replicas nbsrv(replica_nodes) eq 0
    monitor fail if !is_replica !is_primary
    monitor fail if !is_replica is_primary !no_replicas
