[global]
 
# ── Repo 1: AWS S3 af-south-1 ────────────────────────────────────────────
repo1-type=s3
repo1-s3-bucket=lamisplus-pg-backups
repo1-s3-endpoint=s3.af-south-1.amazonaws.com
repo1-s3-region=af-south-1
repo1-s3-key=AKIA5GBWTJDWR2S446TD
repo1-s3-key-secret=<YOUR_SECRET_HERE>
repo1-path=/pgbackrest
repo1-retention-full=2
repo1-retention-diff=4
repo1-retention-archive=30
# repo1-cipher-type=aes-256-cbc
# repo1-cipher-pass=CHANGE_ME
 
# ── WAL Archiving ────────────────────────────────────────────────────────
archive-async=y
spool-path=/var/spool/pgbackrest
archive-timeout=60
archive-push-queue-max=1024MB
 
# ── Backup Behaviour ─────────────────────────────────────────────────────
start-fast=y
backup-standby=y
 
# ── Performance & Compression ────────────────────────────────────────────
process-max=2
compress-type=zst
compress-level=3
 
# ── Logging ──────────────────────────────────────────────────────────────
log-level-console=info
log-level-file=info
log-level-stderr=error
log-path=/var/log/pgbackrest
 
# ── Stanza: lamisplus ────────────────────────────────────────────────────
[lamisplus]
 
# pg1 = this node (node-2). Local socket — no pg1-host.
pg1-path=/data/patroni
pg1-port=5432
 
# pg2 = node-1 (preferred standby for file copy via SSH)
pg2-path=/data/patroni
pg2-host=172.31.10.62
pg2-host-user=postgres
pg2-port=5432
